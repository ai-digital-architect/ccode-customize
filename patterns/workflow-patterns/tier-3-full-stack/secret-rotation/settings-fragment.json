{
  "permissions": {
    "allow": [
      "Bash(grep -rn *)",
      "Bash(find *)",
      "Bash(cat *)",
      "Bash(mkdir -p .claude/secrets)"
    ],
    "deny": [
      "Bash(curl * | bash)",
      "Bash(rm -rf /:*)"
    ]
  },
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "bash .claude/hooks/require-health-before-revoke.sh"
          }
        ]
      }
    ]
  }
}
