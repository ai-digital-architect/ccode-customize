{
  "permissions": {
    "allow": [
      "Bash(pnpm test:*)",
      "Bash(pnpm test --reporter=json)",
      "Bash(mkdir -p .claude/regression)"
    ]
  },
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Write|Edit|MultiEdit",
        "hooks": [
          {
            "type": "command",
            "command": "bash .claude/hooks/capture-baseline.sh"
          }
        ]
      }
    ]
  }
}
